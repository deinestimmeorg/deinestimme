# DeineStimme — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und trage deine Supabase-Keys ein.
# .env.local wird von git ignoriert.

VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Ohne Supabase-Keys läuft die App im Offline-Modus:
# - Landing, /verstehen, /mitbauen, /institution, /zustaendigkeit funktionieren voll
# - /app funktioniert ohne Realtime-Subscription (kein Live-Pulse von Proposals)
# - Profil-Anlage in WelcomeScreen fällt auf localStorage-Offline-Modus zurück
